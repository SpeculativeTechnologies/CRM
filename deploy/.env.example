# ── Copy this to `.env` on the VM and fill in the values marked CHANGE_ME ──

# Your custom image on GHCR. Replace YOURUSER with your GitHub username (lowercase).
# Use :latest, or pin to a commit SHA for reproducible deploys / easy rollback.
IMAGE=ghcr.io/YOURUSER/twenty:latest

# Public URL of your instance — MUST match the domain in Caddyfile exactly,
# including https://. Auth and redirects break if this is wrong.
SERVER_URL=https://crm.yourdomain.com

# ── Secrets — generate with: openssl rand -base64 32 ──
# Protects all stored secrets. BACK THIS UP. Losing it = losing encrypted data.
ENCRYPTION_KEY=CHANGE_ME
# Only set this during a key rotation (previous ENCRYPTION_KEY). Leave blank otherwise.
FALLBACK_ENCRYPTION_KEY=

# ── Database ──
# Strong password, no special characters (it goes into a connection URL).
PG_DATABASE_PASSWORD=CHANGE_ME
#PG_DATABASE_USER=postgres
#PG_DATABASE_HOST=db
#PG_DATABASE_PORT=5432
#PG_DATABASE_NAME=default

#REDIS_URL=redis://redis:6379

# ── File storage ──
# `local` uses a docker volume (fine to start). Switch to `s3` for real prod.
STORAGE_TYPE=local
#STORAGE_S3_REGION=eu-west-3
#STORAGE_S3_NAME=my-bucket
#STORAGE_S3_ENDPOINT=
#STORAGE_S3_ACCESS_KEY_ID=
#STORAGE_S3_SECRET_ACCESS_KEY=

# ── Email (needed for invites / password resets) ──
#EMAIL_FROM_ADDRESS=contact@yourdomain.com
#EMAIL_FROM_NAME=John from YourDomain
#EMAIL_DRIVER=smtp
#EMAIL_SMTP_HOST=smtp.example.com
#EMAIL_SMTP_PORT=465
#EMAIL_SMTP_USER=
#EMAIL_SMTP_PASSWORD=
